# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# NVIDIA_API_KEY: Required for multi-model Nvidia NIM testing.
# Get this from build.nvidia.com
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_CLIENT_ID & GITHUB_CLIENT_SECRET: For GitHub OAuth integration
GITHUB_CLIENT_ID="MY_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="MY_GITHUB_CLIENT_SECRET"

# GITHUB_WEBHOOK_SECRET: To verify incoming webhooks from GitHub
GITHUB_WEBHOOK_SECRET="MY_GITHUB_WEBHOOK_SECRET"

# If using a GitHub App (Recommended for AutoQA Webhooks & PR Comments)
GITHUB_APP_ID="123456"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# If using a Personal Access Token (PAT) instead of a GitHub App
# Get this from Developer Settings -> Personal Access Tokens (starts with ghp_ or github_pat_)
GITHUB_TOKEN="ghp_xxxxxxxxxxxx"

# SUPABASE INTEGRATION
VITE_SUPABASE_URL="https://qxpcbhjqpxbnkwvhrdri.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ... (your anon key)"
SUPABASE_URL="https://qxpcbhjqpxbnkwvhrdri.supabase.co"
SUPABASE_ANON_KEY="eyJ... (your anon key)"
SUPABASE_SERVICE_ROLE_KEY="eyJ... (your service role key)"
# Add your real password here in your secrets menu to allow creating tables
# Example: postgresql://postgres.qxpcbhjqpxbnkwvhrdri:MY_ACTUAL_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL="postgresql://postgres.qxpcbhjqpxbnkwvhrdri:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"
